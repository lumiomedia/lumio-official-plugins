{
  "id": "lumio-official",
  "name": "Lumio Official",
  "description": "Official Lumio plugin marketplace. One repository can publish multiple plugins through this manifest.",
  "repoUrl": "https://github.com/lumiomedia/lumio-official-plugins",
  "visibility": "private-for-now",
  "plugins": [
    {
      "id": "com.lumio.youtube",
      "slug": "youtube",
      "name": {
        "en": "YouTube",
        "sv": "YouTube"
      },
      "version": "1.0.5",
      "description": {
        "en": "Browse subscriptions, watch later, playlists and channels from YouTube.",
        "sv": "Bläddra bland prenumerationer, titta senare, spellistor och kanaler från YouTube."
      },
      "path": "plugins/youtube",
      "runtimeBundlePath": "dist/runtime.js",
      "readmePath": "plugins/youtube/README.md",
      "changelogPath": "plugins/youtube/CHANGELOG.md",
      "official": true,
      "bundled": true,
      "removable": true,
      "auth": {
        "managedProviderId": "google-youtube",
        "supportsPersonalOverride": true
      }
    },
    {
      "id": "com.lumio.plex",
      "slug": "plex",
      "name": {
        "en": "Plex",
        "sv": "Plex"
      },
      "version": "1.0.27",
      "description": {
        "en": "Browse and play media from your Plex Media Server.",
        "sv": "Bläddra i och spela upp media från din Plex Media Server."
      },
      "path": "plugins/plex",
      "runtimeBundlePath": "dist/runtime.js",
      "readmePath": "plugins/plex/README.md",
      "changelogPath": "plugins/plex/CHANGELOG.md",
      "official": true,
      "bundled": true,
      "removable": true
    },
    {
      "id": "com.lumio.live-tv",
      "slug": "live-tv",
      "name": {
        "en": "Live TV",
        "sv": "Live TV"
      },
      "version": "0.2.3",
      "description": {
        "en": "Manage M3U sources and browse live TV channels inside Lumio.",
        "sv": "Hantera M3U-källor och live-tv-kanaler i Lumio."
      },
      "path": "plugins/live-tv",
      "runtimeBundlePath": "dist/runtime.js",
      "readmePath": "plugins/live-tv/README.md",
      "changelogPath": "plugins/live-tv/CHANGELOG.md",
      "official": true,
      "bundled": true,
      "removable": true
    },
    {
      "id": "com.lumio.homekit",
      "slug": "homekit",
      "name": {
        "en": "HomeKit",
        "sv": "HomeKit"
      },
      "version": "0.2.2",
      "description": {
        "en": "Connect Lumio playback events to HomeKit scenes and automations.",
        "sv": "Koppla Lumios uppspelningshändelser till HomeKit-scener och automationer."
      },
      "path": "plugins/homekit",
      "runtimeBundlePath": "dist/runtime.js",
      "readmePath": "plugins/homekit/README.md",
      "changelogPath": "plugins/homekit/CHANGELOG.md",
      "official": true,
      "bundled": true,
      "removable": true
    },
    {
      "id": "com.lumio.trakt",
      "slug": "trakt",
      "name": {
        "en": "Trakt",
        "sv": "Trakt"
      },
      "version": "0.2.2",
      "description": {
        "en": "Sync watched history, watchlists and collection data with Trakt.",
        "sv": "Synka visningshistorik, listor och samlingsdata med Trakt."
      },
      "path": "plugins/trakt",
      "runtimeBundlePath": "dist/runtime.js",
      "readmePath": "plugins/trakt/README.md",
      "changelogPath": "plugins/trakt/CHANGELOG.md",
      "official": true,
      "bundled": true,
      "removable": true
    }
  ]
}
