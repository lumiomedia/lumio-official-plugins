{
  "id": "lumio-official",
  "name": "Lumio Official",
  "description": "Official Lumio plugin marketplace. One repository can publish multiple plugins through this manifest.",
  "repoUrl": "https://github.com/lumiomedia/lumio-official-plugins",
  "visibility": "private-for-now",
  "plugins": [
    {
      "id": "com.lumio.youtube",
      "slug": "youtube",
      "name": "YouTube",
      "version": "1.0.0",
      "description": "Browse subscriptions, watch later, playlists and channels from YouTube.",
      "path": "plugins/youtube",
      "runtimeBundlePath": "dist/runtime.js",
      "readmePath": "plugins/youtube/README.md",
      "changelogPath": "plugins/youtube/CHANGELOG.md",
      "official": true,
      "bundled": true,
      "removable": true,
      "auth": {
        "managedProviderId": "google-youtube",
        "supportsPersonalOverride": true
      }
    },
    {
      "id": "com.lumio.plex",
      "slug": "plex",
      "name": "Plex",
      "version": "1.0.2",
      "description": "Browse and play media from your Plex Media Server.",
      "path": "plugins/plex",
      "runtimeBundlePath": "dist/runtime.js",
      "readmePath": "plugins/plex/README.md",
      "changelogPath": "plugins/plex/CHANGELOG.md",
      "official": true,
      "bundled": true,
      "removable": true
    },
    {
      "id": "com.lumio.live-tv",
      "slug": "live-tv",
      "name": "Live TV",
      "version": "0.1.1",
      "description": "Manage M3U sources and browse live TV channels inside Lumio.",
      "path": "plugins/live-tv",
      "runtimeBundlePath": "dist/runtime.js",
      "readmePath": "plugins/live-tv/README.md",
      "changelogPath": "plugins/live-tv/CHANGELOG.md",
      "official": true,
      "bundled": true,
      "removable": true
    },
    {
      "id": "com.lumio.homekit",
      "slug": "homekit",
      "name": "HomeKit",
      "version": "0.1.1",
      "description": "Connect Lumio playback events to HomeKit scenes and automations.",
      "path": "plugins/homekit",
      "runtimeBundlePath": "dist/runtime.js",
      "readmePath": "plugins/homekit/README.md",
      "changelogPath": "plugins/homekit/CHANGELOG.md",
      "official": true,
      "bundled": true,
      "removable": true
    },
    {
      "id": "com.lumio.trakt",
      "slug": "trakt",
      "name": "Trakt",
      "version": "0.1.1",
      "description": "Sync watched history, watchlists and collection data with Trakt.",
      "path": "plugins/trakt",
      "runtimeBundlePath": "dist/runtime.js",
      "readmePath": "plugins/trakt/README.md",
      "changelogPath": "plugins/trakt/CHANGELOG.md",
      "official": true,
      "bundled": true,
      "removable": true
    }
  ]
}
